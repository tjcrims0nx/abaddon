# Abaddon AI API Keys
# Rename this file to .env and fill in your keys to use Abaddon.
# You only need the keys for the specific model providers you plan to use!

# Google (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Nvidia NIM (OpenAI-compatible)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Aliyun DashScope (Qwen)
QWEN_API_KEY=your_qwen_api_key_here

# MuleRouter (Multi-model routing)
MULEROUTER_API_KEY=your_mulerouter_api_key_here

# OpenRouter (Multi-model routing)
OPENROUTER_API_KEY=your_openrouter_api_key_here
